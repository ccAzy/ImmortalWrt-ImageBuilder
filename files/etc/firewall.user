# TR3000 应急防火墙规则 — 仅当 fw4 (nftables) 故障时由 nat-fix 调用
# ⚠️ 此脚本会清空现有 iptables 规则，仅在 fw4 崩溃时作为兜底
# 正常运行时不执行（nat-fix 会检测 fw4 状态后跳过）
iptables -F FORWARD
iptables -t nat -F POSTROUTING

# NAT 伪装
iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE

# 转发
iptables -A FORWARD -i br-lan -o eth0 -j ACCEPT
iptables -A FORWARD -i eth0 -o br-lan -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
iptables -A FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
